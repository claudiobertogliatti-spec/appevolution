{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "create-react-app",
  "buildCommand": "DISABLE_ESLINT_PLUGIN=true CI=false npm run build",
  "outputDirectory": "build",
  "installCommand": "npm install --legacy-peer-deps",
  "redirects": [
    {
      "source": "/analisi",
      "destination": "/ciak-blueprint",
      "permanent": true
    },
    {
      "source": "/analisi/grazie",
      "destination": "/ciak-blueprint/grazie",
      "permanent": true
    },
    {
      "source": "/analisi-strategica",
      "destination": "/ciak-blueprint",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://evolution-pro-backend-dc2gzjsmdq-ew.a.run.app/api/$1"
    },
    {
      "source": "/((?!api/|static/|ciak/|images/|agents/|favicon|apple-touch-icon|site\\.webmanifest|og-|robots|sitemap|llms|index\\.).*)?",
      "has": [{ "type": "host", "value": "(www\\.)?ciak\\.io" }],
      "destination": "/index.ciak.html"
    },
    {
      "source": "/((?!api/|static/|ciak/|images/|agents/|favicon|apple-touch-icon|site\\.webmanifest|og-|robots|sitemap|llms|index\\.).*)?",
      "destination": "/index.evolution.html"
    }
  ],
  "headers": [
    {
      "source": "/ciak/(.*\\.webp)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/og-(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800" }
      ]
    },
    {
      "source": "/index.evolution.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.ciak.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
